{
	"name": "rpg-master-plugin",
	"version": "1.0.0",
	"description": "An Obsidian plugin to play RPG games with friends. This is the master plugin, which manages the game state and communicates with player plugins.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "vite build --watch --mode development",
		"build": "tsc -noEmit -skipLibCheck && vite build",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"start_test_server": "vite test --host 127.0.0.1 --port 5173 --strictPort --open",
		"lint": "eslint ."
	},
	"keywords": [],
	"license": "0-BSD",
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@types/node": "^20.17.0",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1",
		"vite": "^6.2.0"
	},
	"dependencies": {
		"@preact/signals": "^2.8.1",
		"obsidian": "1.12.3",
		"peerjs": "^1.5.5"
	}
}
